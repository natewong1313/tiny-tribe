{
	"name": "tiny-tribe",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"compile": "cloesce compile",
		"migrate:cloesce": "cloesce migrate",
		"migrate:wrangler": "wrangler d1 migrations apply tiny-tribe-db --local",
		"dev": "vite dev --port 3000",
		"build": "vite build",
		"start": "vite preview",
		"line": "bun run lint",
		"lint": "oxlint --config .oxlintrc.json",
		"format:check": "oxfmt --check src",
		"format": "oxfmt --write src",
		"type-check": "tsc --noEmit --project tsconfig.json",
		"prepare": "husky"
	},
	"dependencies": {
		"better-auth": "^1.5.5",
		"cloesce": "^0.2.2",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.13.6",
		"@cloudflare/workers-types": "^4.20260130.0",
		"@remixicon/react": "^4.9.0",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-rsc": "^0.5.21",
		"babel-plugin-react-compiler": "1.0.0",
		"clsx": "^2.1.1",
		"husky": "^9.1.7",
		"oxc-transform": "^0.58.1",
		"oxfmt": "^0.40.0",
		"oxlint": "^0.15.15",
		"react-server-dom-webpack": "^19.2.4",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4",
		"typescript": "^5",
		"vinext": "^0.0.30",
		"vite": "^8.0.0"
	},
	"ignoreScripts": [
		"sharp",
		"unrs-resolver"
	],
	"trustedDependencies": [
		"sharp",
		"unrs-resolver"
	],
	"type": "module"
}
